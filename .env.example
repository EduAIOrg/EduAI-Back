# Database
DATABASE_URL=postgresql+asyncpg://eduai:eduai_password@localhost:5432/eduai

# Security
SECRET_KEY=your-super-secret-key-min-32-chars-change-this-in-production
ACCESS_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_EXPIRE_DAYS=30

# Hugging Face Settings
HF_TOKEN=hf_your_token_here
HF_LLM_MODEL=Qwen/Qwen3-14B-Instruct
HF_EMBEDDING_MODEL=intfloat/multilingual-e5-large
HF_RERANK_MODEL=BAAI/bge-reranker-large

# CORS & Upload
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
MAX_UPLOAD_SIZE_MB=50
UPLOADS_DIR=./uploads

SUPABASE_URL=https://[votre-id-projet].supabase.co
SUPABASE_KEY=[votre-cle-service-role-ou-anon]
SUPABASE_BUCKET=eduai-documents

# App
APP_NAME=EduAI Africa
APP_VERSION=1.0.0
DEBUG=true